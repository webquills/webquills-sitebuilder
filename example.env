#######################################################################
# Environment variables for Webquills Sitebuilder
# Copy this file to ".env" and modify as needed for your setup.
# Do NOT check in your modified .env file to version control!
#
# WARNING: This file is used both by Docker Compose and by Django directly.
# The syntax is therefore constrained to what can be parsed by django-environ.
# No bash-specific syntax (like ${VAR} or ~) is allowed!
# Be sure django-environ is initialized with `interpolate=True`.
#######################################################################

#######################################################################
# Local Development (without Docker)
#######################################################################
# When running locally without Docker, Django will use SQLite by default.
DEBUG=True
SECRET_KEY="Not a secret! Never check secrets into git! Change this."

# Used by VSCode to enable Django test integration
MANAGE_PY_PATH="./manage.py"

# To use Redis for caching, uncomment:
# REDIS_URL="redis://localhost:6379/0"

#######################################################################
# Docker Compose Configuration
#######################################################################
# When using Docker Compose, the settings below configure all services.
# Comment out DATABASE_URL and REDIS_URL if running locally without Docker.

# User and Group IDs (defaults to current user for dev)
UID=1000
GID=1000

# Project directory - base path for data volumes
# Set this to your local project path or use $PWD in your shell
PROJECT_DIR=$PWD
DATA_DIR=$PROJECT_DIR/var

# Django image configuration
DJANGO_IMAGE=webquills-sitebuilder:dev

# PostgreSQL configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Django database configuration
DJANGO_DB_NAME=webquills
DJANGO_DB_USER=webquills
DJANGO_DB_PASSWORD=webquills
DATABASE_URL=postgresql://$DJANGO_DB_USER:$DJANGO_DB_PASSWORD@$POSTGRES_HOST:$POSTGRES_PORT/$DJANGO_DB_NAME

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://$REDIS_HOST:$REDIS_PORT/$REDIS_DB


# Gitea database configuration
GITEA_DB_NAME=gitea
GITEA_DB_USER=gitea
GITEA_DB_PASSWORD=gitea

# Gitea configuration
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222
GITEA_ROOT_URL=http://localhost:3000/
GITEA_DISABLE_REGISTRATION=false

#!/usr/bin/env bash

# Based on the Taskfile format from https://github.com/adriancooney/Taskfile
# Please keep functions sorted alphabetically for ease of editing.

# A useful path mod
PATH=./node_modules/.bin:$PATH

#######################################################################
# Set some commonly used globals
#######################################################################
BASE_DIR=$(cd `dirname $0`; pwd)
PROJECT_NAME=`basename "$BASE_DIR"`

#######################################################################
# Function declarations
#######################################################################
function help { ## Display usage for this application
    echo "$0 <task> <args>"
    echo "Tasks:"
    # compgen -A function | cat -n
    grep -E '^function [a-zA-Z_-]+ {.*?## .*$' $0 | \
        sed -e 's/function //' | \
        sort | \
        awk 'BEGIN {FS = "{.*?## "}; {printf "\033[93m%-30s\033[92m %s\033[0m\n", $1, $2}'
}

function gitea { ## Execute gitea CLI in the gitea container (connects to running container or starts new one)
    # Check if Gitea container is running
    if docker ps --format '{{.Names}}' | grep -q '^webquills-gitea$'; then
        # Container is running, exec into it
        docker exec -it webquills-gitea gitea "$@"
    else
        # Container is not running, start a new one
        docker compose run --rm gitea gitea "$@"
    fi
}

function manage { ## Run Django manage.py commands (connects to running container or starts new one)
    # Check if Django container is running
    if docker ps --format '{{.Names}}' | grep -q '^webquills-django$'; then
        # Container is running, exec into it
        docker exec -it webquills-django uv run python manage.py "$@"
    else
        # Container is not running, start a new one
        docker compose run --rm django uv run python manage.py "$@"
    fi
}

function _confirm_yes_no {
    local prompt="$1"
    local default=${2:-no}
    if [[ "$NONINTERACTIVE" == "1" || "$AUTO_YES" == "1" ]]; then
        return 0
    fi
    read -p "$prompt [y/N]: " ans
    case "$ans" in
        [Yy]|[Yy][Ee][Ss]) return 0 ;;
        *) return 1 ;;
    esac
}

function nuke { ## Remove docker compose volumes and delete DATA_DIR (destructive)
    # Safety: determine DATA_DIR from environment or example.env
    DATA_DIR_ENV=${DATA_DIR:-}
    if [[ -z "$DATA_DIR_ENV" ]]; then
        # try to source .env or example.env
        if [[ -f .env ]]; then
            # shellcheck disable=SC1091
            source .env
        fi
        DATA_DIR_ENV=${DATA_DIR:-}
    fi
    echo "#######################################################################"
    echo "This will PERMANENTLY DESTROY ALL LOCAL DATA for this project."
    echo "#######################################################################"
    echo "Docker volumes to remove:"
    echo " - webquills_postgres_data"
    echo " - webquills_redis_data"
    echo " - webquills_gitea_data"
    echo " - webquills_venv"
    if [[ -n "$DATA_DIR_ENV" ]]; then
        echo "Local DATA_DIR to delete: $DATA_DIR_ENV"
    else
        echo "Warning: DATA_DIR could not be determined from environment; skipping host file deletion."
    fi

    if ! _confirm_yes_no "Are you sure you want to continue?"; then
        echo "Aborting nuke. No changes made."
        return 1
    fi

    # stop compose
    echo "Stopping containers..."
    docker compose down || true

    # remove named volumes (ignore errors)
    echo "Removing docker volumes..."
    docker volume rm webquills-sitebuilder_webquills_gitea_data webquills-sitebuilder_webquills_postgres_data webquills-sitebuilder_webquills_redis_data webquills-sitebuilder_webquills_venv || true

    # remove DATA_DIR contents if it's inside the project dir for safety
    if [[ -n "$DATA_DIR_ENV" ]]; then
        # Resolve absolute paths
        DATA_DIR_ABS=$(cd "$DATA_DIR_ENV" 2>/dev/null && pwd || echo "")
        BASE_DIR_ABS="$BASE_DIR"
        if [[ -z "$DATA_DIR_ABS" ]]; then
            echo "Could not resolve DATA_DIR path '$DATA_DIR_ENV'; skipping host delete."
        else
            # Ensure DATA_DIR is within the project directory to avoid catastrophic deletes
            if [[ "$DATA_DIR_ABS" == "$BASE_DIR_ABS"* ]]; then
                echo "Deleting contents of $DATA_DIR_ABS..."
                rm -rf "$DATA_DIR_ABS"/*
                echo "Deleted contents of $DATA_DIR_ABS."
            else
                echo "Refusing to delete '$DATA_DIR_ABS' because it is outside the project directory ($BASE_DIR_ABS)."
                echo "If you really want to remove it, please run the command manually."
            fi
        fi
    fi

    echo "Nuke complete."
}

function setup_gitea { ## Initialize Gitea, create admin user, and configure Django SocialApp
    echo "Setting up Gitea..."
    
    # Load environment variables from .env if it exists
    if [[ -f .env ]]; then
        # shellcheck disable=SC1091
        source .env
    fi
    
    # Ensure DATA_DIR is set
    DATA_DIR=${DATA_DIR:-"$BASE_DIR/var"}
    mkdir -p "$DATA_DIR/gitea"
    
    # Check for required environment variables
    if [[ -z "${GITEA_ADMIN_USER:-}" ]]; then
        echo "Error: GITEA_ADMIN_USER environment variable is not set"
        echo "Please set it in your .env file"
        return 1
    fi
    
    if [[ -z "${GITEA_ADMIN_EMAIL:-}" ]]; then
        echo "Error: GITEA_ADMIN_EMAIL environment variable is not set"
        echo "Please set it in your .env file"
        return 1
    fi
    
    # Run gitea migrate to ensure DB is initialized
    echo "Running Gitea database migration..."
    gitea migrate || {
        echo "Error: Failed to run gitea migrate"
        return 1
    }
    
    # Check if admin user exists
    echo "Checking if admin user exists..."
    if gitea admin user list | grep -q "^$GITEA_ADMIN_USER"; then
        echo "Admin user '$GITEA_ADMIN_USER' already exists"
    else
        echo "Creating admin user '$GITEA_ADMIN_USER'..."
        # Generate a random password
        ADMIN_PASSWORD=$(openssl rand -base64 32)
        ADMIN_PASSWORD_FILE="$DATA_DIR/gitea/admin_password.txt"
        echo "$ADMIN_PASSWORD" > "$ADMIN_PASSWORD_FILE"
        chmod 600 "$ADMIN_PASSWORD_FILE"
        
        gitea admin user create \
            --username "$GITEA_ADMIN_USER" \
            --email "$GITEA_ADMIN_EMAIL" \
            --password "$ADMIN_PASSWORD" \
            --admin || {
            echo "Error: Failed to create admin user"
            return 1
        }
        
        echo "Admin user created. Password saved to: $ADMIN_PASSWORD_FILE"
    fi
    
    # Generate admin token
    echo "Generating admin token..."
    ADMIN_TOKEN_FILE="$DATA_DIR/gitea/admin_token.txt"
    
    # Delete old token if it exists
    if [[ -f "$ADMIN_TOKEN_FILE" ]]; then
        OLD_TOKEN=$(cat "$ADMIN_TOKEN_FILE")
        gitea admin user oauth2 delete-token --username "$GITEA_ADMIN_USER" --token "$OLD_TOKEN" 2>/dev/null || true
    fi
    
    # Generate new token
    ADMIN_TOKEN=$(gitea admin user generate-access-token \
        --username "$GITEA_ADMIN_USER" \
        --scopes all \
        --token-name "Django SocialApp Token" | grep "^Access token:" | awk '{print $3}')
    
    if [[ -z "$ADMIN_TOKEN" ]]; then
        echo "Error: Failed to generate admin token"
        return 1
    fi
    
    echo "$ADMIN_TOKEN" > "$ADMIN_TOKEN_FILE"
    chmod 600 "$ADMIN_TOKEN_FILE"
    echo "Admin token saved to: $ADMIN_TOKEN_FILE"
    
    # Update Django SocialApp
    echo "Updating Django SocialApp for Gitea..."
    manage create_socialapp \
        --provider gitea \
        --name "Gitea" \
        --client-id "$GITEA_ADMIN_USER" \
        --secret-file "$ADMIN_TOKEN_FILE" || {
        echo "Error: Failed to create/update Django SocialApp"
        return 1
    }
    
    echo "Gitea setup complete!"
}

#######################################################################
# Finally, execute it.
#######################################################################

TIMEFORMAT="Task completed in %3lR"
# Replace "help" with the name of the desired default function
time ${@:-help}
